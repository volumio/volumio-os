#!/bin/sh
# prepare-ota-storage: one-time resize of boot and image partitions to Pi layout
# for OTA headroom. Runs in initramfs (BusyBox ash). POSIX sh only.

TARGET_BOOT_END=385
TARGET_IMAGE_END=4673
RESERVED_VT=2
NORMAL_VT=1
STAGE_SIZE_SECTORS=128
BOOT_BACKUP_MB=385
OTA_MOUNT=/mnt/ota_data

# BOOT_BACKUP_MB is the backup SLOT size (used for seek/skip offsets to position
# the image backup after the boot backup in the tail area).
# BOOT_PART_SIZE is the actual boot partition size in MiB (start=1, end=TARGET_BOOT_END).
# These differ by 1 because parted's start offset is 1 MiB, not 0.
# dd count MUST use BOOT_PART_SIZE when writing TO the boot partition device,
# otherwise the last block overflows the device and dd returns non-zero.
BOOT_PART_SIZE=$((TARGET_BOOT_END - 1))

# Write stage magic and value to last 64K of disk (for recovery)
# Usage: write_stage 0|1|2  (ASCII digit written after "VOLRESIZE")
write_stage() {
	_stage_val="$1"
	_dev="$2"
	_size_sect=""
	if [ -z "${_dev}" ]; then return 1; fi
	_block="${_dev#/dev/}"
	[ -f "/sys/block/${_block}/size" ] || return 1
	_size_sect=$(cat "/sys/block/${_block}/size" 2>/dev/null)
	[ -n "${_size_sect}" ] || return 1
	_seek_sect=$((_size_sect - STAGE_SIZE_SECTORS))
	_payload=$(printf "VOLRESIZE%s" "${_stage_val}")
	printf "%s" "${_payload}" | dd of="${_dev}" bs=512 seek="${_seek_sect}" conv=fsync 2>/dev/null
	return $?
}

read_stage() {
	_dev="$1"
	_size_sect=""
	_seek_sect=""
	if [ -z "${_dev}" ]; then echo "0"; return; fi
	_block="${_dev#/dev/}"
	[ -f "/sys/block/${_block}/size" ] || { echo "0"; return; }
	_size_sect=$(cat "/sys/block/${_block}/size" 2>/dev/null)
	[ -n "${_size_sect}" ] || { echo "0"; return; }
	_seek_sect=$((_size_sect - STAGE_SIZE_SECTORS))
	_magic=$(dd if="${_dev}" bs=512 skip="${_seek_sect}" count=1 2>/dev/null | head -c 16)
	case "${_magic}" in
		VOLRESIZE1) echo "1"; return ;;
		VOLRESIZE2) echo "2"; return ;;
		*) echo "0"; return ;;
	esac
}

# Show maintenance message on reserved VT (large text); only call when resize will run
show_maintenance_vt() {
	chvt "${RESERVED_VT}" 2>/dev/null || true
	# Clear and home
	printf '\033[2J\033[H' > "/dev/tty${RESERVED_VT}" 2>/dev/null || true
	echo "" > "/dev/tty${RESERVED_VT}" 2>/dev/null || true
	echo "========================================" > "/dev/tty${RESERVED_VT}" 2>/dev/null || true
	echo "  MAINTENANCE - Do not disconnect power" > "/dev/tty${RESERVED_VT}" 2>/dev/null || true
	echo "  This may take several minutes." > "/dev/tty${RESERVED_VT}" 2>/dev/null || true
	echo "========================================" > "/dev/tty${RESERVED_VT}" 2>/dev/null || true
	echo "" > "/dev/tty${RESERVED_VT}" 2>/dev/null || true
}

switch_back_vt() {
	chvt "${NORMAL_VT}" 2>/dev/null || true
}

# Update step progress on the reserved VT.
# Cursor positioned at row 8 (below the banner), clearing the line each time
# so each step overwrites the previous one. The banner stays on screen.
# Args: $1 = current step, $2 = total steps, $3 = description
progress_msg() {
	printf '\033[8;1H  Step %s of %s: %-40s' "$1" "$2" "$3" \
		> "/dev/tty${RESERVED_VT}" 2>/dev/null || true
}

# Resolve UUID= or LABEL= to /dev/... path so -b and lsblk/dd/mount work in initramfs
resolve_partition_to_device() {
	_spec="$1"
	[ -z "${_spec}" ] && return
	case "${_spec}" in
		/dev/*) echo "${_spec}"; return ;;
		UUID=*|LABEL=*) _d=$(findfs "${_spec}" 2>/dev/null); [ -n "${_d}" ] && echo "${_d}"; return ;;
		*) echo "${_spec}"; return ;;
	esac
}

# Expand a restored vfat boot partition to fill its device.
# dd restore writes the original (smaller) vfat image block-for-block.
# The BPB still describes the old size (e.g. 244 MiB on a now-384 MiB partition).
# No in-place fatresize exists in BusyBox, so: mount old vfat, copy files to
# tmpfs staging, unmount, mkfs.vfat at full partition size, mount, copy back.
# Args: $1 = partition device, $2 = mount point (temporary)
expand_boot_vfat() {
	_edev="$1"
	_emnt="$2"
	_staging=""

	[ -b "${_edev}" ] || return 1

	_staging=$(mktemp -d /run/boot_staging.XXXXXX 2>/dev/null) || return 1

	# Mount the restored (old-size) vfat
	if ! mount -t vfat -o ro "${_edev}" "${_emnt}" 2>/dev/null; then
		rm -rf "${_staging}"
		return 1
	fi

	# Copy all files preserving timestamps
	if ! cp -a "${_emnt}/." "${_staging}/" 2>/dev/null; then
		umount "${_emnt}" 2>/dev/null || true
		rm -rf "${_staging}"
		return 1
	fi
	umount "${_emnt}" 2>/dev/null || true

	# Create full-size vfat
	if ! mkfs.vfat -n BOOT "${_edev}" 2>/dev/null; then
		rm -rf "${_staging}"
		return 1
	fi

	# Mount new full-size vfat and copy files back
	if ! mount -t vfat "${_edev}" "${_emnt}" 2>/dev/null; then
		rm -rf "${_staging}"
		return 1
	fi
	cp -a "${_staging}/." "${_emnt}/" 2>/dev/null
	sync
	umount "${_emnt}" 2>/dev/null || true

	rm -rf "${_staging}"
	return 0
}

# Expand a restored ext4 image partition to fill its device.
# dd restore writes the original (smaller) ext4 image block-for-block.
# The superblock still describes the old size. resize2fs expands in-place.
# Args: $1 = partition device
expand_image_ext4() {
	_edev="$1"

	[ -b "${_edev}" ] || return 1

	# e2fsck required before resize2fs (resize2fs may refuse a dirty fs)
	e2fsck -fy "${_edev}" >/dev/null 2>&1 || true

	# resize2fs with no size argument expands to fill the partition
	if ! resize2fs "${_edev}" >/dev/null 2>&1; then
		return 1
	fi
	return 0
}

# Check whether a mounted filesystem is undersized relative to its partition.
# Compares filesystem total (from df) against partition size (from lsblk).
# Returns 0 if undersized (needs expansion), 1 if OK or unknown.
# Args: $1 = partition device (must be currently mounted)
check_fs_undersized() {
	_cdev="$1"
	[ -b "${_cdev}" ] || return 1

	# Filesystem total in 1K blocks (from df, filtered by device)
	_fs_total_k=$(df -k 2>/dev/null | awk -v dev="${_cdev}" '$1==dev {print $2; exit}')
	[ -n "${_fs_total_k}" ] || return 1

	# Partition size in 1K blocks (from lsblk in bytes, divided)
	_part_bytes=$(lsblk -bno SIZE "${_cdev}" 2>/dev/null)
	[ -n "${_part_bytes}" ] || return 1
	_part_k=$((_part_bytes / 1024))

	# If filesystem total is less than 90% of partition size, it needs expansion.
	# 90% threshold accounts for normal filesystem overhead (journal, reserved blocks)
	# while still catching genuinely undersized filesystems (e.g. 241 MiB on 384 MiB,
	# or 2.7G on 4.2G).
	_threshold=$((_part_k * 9 / 10))
	[ "${_fs_total_k}" -lt "${_threshold}" ] && return 0
	return 1
}

prepare_ota_storage() {
	P1_END=""
	P2_END=""
	IMG_SIZE_MB=""
	SEEK_MB=""
	DEV_SIZE_MB=""
	TAIL_MB=""
	_need_resize=""
	DATADEV=""
	BOOT_DEVICE=""
	IMAGE_DEVICE=""
	DATA_DEVICE=""

	# 1) Resolve partition specs (UUID= or LABEL=) to device paths
	[ -z "${DATA_PARTITION}" ] && return 0
	DATA_DEVICE=$(resolve_partition_to_device "${DATA_PARTITION}")
	[ -z "${DATA_DEVICE}" ] || [ ! -b "${DATA_DEVICE}" ] && return 0
	BOOT_DEVICE=$(resolve_partition_to_device "${BOOT_PARTITION}")
	IMAGE_DEVICE=$(resolve_partition_to_device "${IMAGE_PARTITION}")
	[ -z "${BOOT_DEVICE}" ] || [ ! -b "${BOOT_DEVICE}" ] || [ -z "${IMAGE_DEVICE}" ] || [ ! -b "${IMAGE_DEVICE}" ] && return 0

	DATADEV="/dev/$(lsblk -no PKNAME "${DATA_DEVICE}" 2>/dev/null)"
	[ -n "${DATADEV}" ] && [ -b "${DATADEV}" ] || return 0

	# 2) Parse current layout (parted unit MiB print)
	_part_out=$(parted -s "${DATADEV}" unit MiB print 2>/dev/null)
	[ -n "${_part_out}" ] || return 0

	P1_END=$(echo "${_part_out}" | awk '/^[[:space:]]*1[[:space:]]/ { gsub(/MiB/,"",$3); v=int($3+0); if(v>0) print v; exit }')
	P2_END=$(echo "${_part_out}" | awk '/^[[:space:]]*2[[:space:]]/ { gsub(/MiB/,"",$3); v=int($3+0); if(v>0) print v; exit }')
	[ -n "${P1_END}" ] && [ -n "${P2_END}" ] || return 0

	# 3) Check if resize needed (already at Pi layout)
	if [ "${P1_END}" -ge "${TARGET_BOOT_END}" ] && [ "${P2_END}" -ge "${TARGET_IMAGE_END}" ]; then
		_stage=$(read_stage "${DATADEV}")
		# Recovery: layout is Pi but stage says we were interrupted; restore from tail only
		if [ "${_stage}" = "1" ] || [ "${_stage}" = "2" ]; then
			show_maintenance_vt
			umount "${BOOTMNT}" 2>/dev/null || true
			umount "${IMAGEMNT}" 2>/dev/null || true
			RECOVERY_IMG_MB=$((TARGET_IMAGE_END - TARGET_BOOT_END))
			# count=BOOT_PART_SIZE (384), not BOOT_BACKUP_MB (385):
			# new P1 is 384 MiB (start=1, end=385); writing 385 blocks
			# overflows the device and dd returns non-zero.
			progress_msg 1 5 "Restoring boot partition"
			if dd if="${DATA_DEVICE}" of="${BOOT_DEVICE}" bs=1M skip=0 count="${BOOT_PART_SIZE}" conv=fsync 2>/dev/null; then
				progress_msg 2 5 "Restoring image partition"
				if dd if="${DATA_DEVICE}" of="${IMAGE_DEVICE}" bs=1M skip="${BOOT_BACKUP_MB}" count="${RECOVERY_IMG_MB}" conv=fsync 2>/dev/null; then
					sync
					# Expand restored filesystems to fill their new partitions
					progress_msg 3 5 "Expanding boot filesystem"
					mkdir -p "${BOOTMNT}"
					expand_boot_vfat "${BOOT_DEVICE}" "${BOOTMNT}"
					progress_msg 4 5 "Expanding image filesystem"
					expand_image_ext4 "${IMAGE_DEVICE}"
					# mkfs data partition (fresh)
					progress_msg 5 5 "Preparing data partition"
					/sbin/mke2fsfull -t ext4 -F -L volumio_data "${DATA_DEVICE}" 2>/dev/null || true
					sync
				fi
			fi
			write_stage 0 "${DATADEV}" 2>/dev/null || true
			mount -t vfat "${BOOT_DEVICE}" "${BOOTMNT}" 2>/dev/null || true
			mount -t ext4 "${IMAGE_DEVICE}" "${IMAGEMNT}" 2>/dev/null || true
			switch_back_vt
		fi

		# Repair: partition layout is correct and stage is clean, but filesystems
		# may be undersized. This catches devices where dd restore completed but
		# expansion was missed (e.g. earlier script version without expand step).
		# Boot and image are mounted at this point (by init or by recovery above),
		# so df can compare filesystem size against partition size.
		_boot_expand=""
		_img_expand=""
		if check_fs_undersized "${BOOT_DEVICE}"; then
			_boot_expand=1
		fi
		if check_fs_undersized "${IMAGE_DEVICE}"; then
			_img_expand=1
		fi
		if [ -n "${_boot_expand}" ] || [ -n "${_img_expand}" ]; then
			show_maintenance_vt
			umount "${BOOTMNT}" 2>/dev/null || true
			umount "${IMAGEMNT}" 2>/dev/null || true

			progress_msg 1 3 "Expanding boot filesystem"
			if [ -n "${_boot_expand}" ]; then
				mkdir -p "${BOOTMNT}"
				if ! expand_boot_vfat "${BOOT_DEVICE}" "${BOOTMNT}"; then
					[ -c /dev/kmsg ] && echo "prepare_ota_storage: boot vfat expansion failed" >/dev/kmsg
				fi
			fi

			progress_msg 2 3 "Expanding image filesystem"
			if [ -n "${_img_expand}" ]; then
				if ! expand_image_ext4 "${IMAGE_DEVICE}"; then
					[ -c /dev/kmsg ] && echo "prepare_ota_storage: image ext4 expansion failed" >/dev/kmsg
				fi
			fi

			progress_msg 3 3 "Remounting partitions"
			mount -t vfat "${BOOT_DEVICE}" "${BOOTMNT}" 2>/dev/null || true
			mount -t ext4 "${IMAGE_DEVICE}" "${IMAGEMNT}" 2>/dev/null || true
			switch_back_vt
		fi

		write_stage 0 "${DATADEV}" 2>/dev/null || true
		return 0
	fi

	# 4) Compute image partition size (p2 size in MiB)
	IMG_SIZE_MB=$((P2_END - P1_END))
	[ "${IMG_SIZE_MB}" -gt 0 ] || return 0

	# Device size (from last partition or free)
	DEV_SIZE_MB=$(echo "${_part_out}" | awk '/^Disk \// { gsub(/MiB/,"",$3); print $3+0; exit }')
	[ -n "${DEV_SIZE_MB}" ] && [ "${DEV_SIZE_MB}" -gt 0 ] || return 0

	# Tail size (from TARGET_IMAGE_END to end of disk) must fit the combined backup:
	# BOOT_BACKUP_MB (slot for boot, 385 MiB) + IMG_SIZE_MB (original image content).
	# Check the sum, not each independently, to avoid the case where the tail fits
	# each alone but not both together.
	TAIL_MB=$((DEV_SIZE_MB - TARGET_IMAGE_END))
	if [ "${TAIL_MB}" -lt $((BOOT_BACKUP_MB + IMG_SIZE_MB)) ]; then
		return 0
	fi
	_need_resize=1

	# 5) Show maintenance message (VT). Mount data before unmounting boot so /sbin (and mount) stay available.
	show_maintenance_vt

	mkdir -p "${OTA_MOUNT}"
	_mounted=""
	for _try in 1 2; do
		if mount -t ext4 -o ro "${DATA_DEVICE}" "${OTA_MOUNT}" 2>/dev/null; then
			_mounted=1
			break
		fi
		[ "${_try}" -eq 1 ] && sleep 2
	done
	if [ -z "${_mounted}" ]; then
		if mount -t ext4 "${DATA_DEVICE}" "${OTA_MOUNT}" 2>/dev/null; then
			_mounted=1
		fi
	fi
	if [ -z "${_mounted}" ]; then
		_err=$(mount -t ext4 "${DATA_DEVICE}" "${OTA_MOUNT}" 2>&1)
		[ -c /dev/kmsg ] && echo "prepare_ota_storage: mount ${DATA_DEVICE} failed: ${_err}" >/dev/kmsg
		umount "${OTA_MOUNT}" 2>/dev/null || true
		switch_back_vt
		return 1
	fi

	# Unmount data before raw dd; then unmount boot and imgpart.
	umount "${OTA_MOUNT}" 2>/dev/null || true
	umount "${BOOTMNT}" 2>/dev/null || true
	umount "${IMAGEMNT}" 2>/dev/null || true
	sleep 2
	udevadm settle 2>/dev/null || true

	# P3 start in MiB = end of p2 (offset inside p3 that corresponds to disk 4673 MiB)
	P3_START_MB="${P2_END}"
	SEEK_MB=$((TARGET_IMAGE_END - P3_START_MB))
	[ "${SEEK_MB}" -ge 0 ] || { switch_back_vt; return 1; }

	# 6) Backup boot and image partition to tail of p3 (raw dd; data partition must be unmounted)
	# count=BOOT_BACKUP_MB (385) is safe here: dd reads from the original boot partition
	# which is smaller (e.g. 244 MiB), so dd short-reads at EOF and exits 0.
	progress_msg 1 9 "Backing up boot partition"
	if ! dd if="${BOOT_DEVICE}" of="${DATA_DEVICE}" bs=1M seek="${SEEK_MB}" count="${BOOT_BACKUP_MB}" conv=fsync 2>/dev/null; then
		switch_back_vt
		return 1
	fi
	progress_msg 2 9 "Backing up image partition"
	if ! dd if="${IMAGE_DEVICE}" of="${DATA_DEVICE}" bs=1M seek=$((SEEK_MB + BOOT_BACKUP_MB)) count="${IMG_SIZE_MB}" conv=fsync 2>/dev/null; then
		switch_back_vt
		return 1
	fi
	sync

	write_stage 1 "${DATADEV}" 2>/dev/null || true

	# 8) Recreate partition table
	progress_msg 3 9 "Recreating partition table"
	if ! parted -s "${DATADEV}" mklabel msdos 2>/dev/null; then
		switch_back_vt
		return 1
	fi
	if ! parted -s "${DATADEV}" unit MiB mkpart primary fat32 1 "${TARGET_BOOT_END}" 2>/dev/null; then
		switch_back_vt
		return 1
	fi
	if ! parted -s "${DATADEV}" unit MiB mkpart primary ext4 "${TARGET_BOOT_END}" "${TARGET_IMAGE_END}" 2>/dev/null; then
		switch_back_vt
		return 1
	fi
	if ! parted -s "${DATADEV}" unit MiB mkpart primary ext4 "${TARGET_IMAGE_END}" 100% 2>/dev/null; then
		switch_back_vt
		return 1
	fi
	if ! parted -s "${DATADEV}" set 1 boot on 2>/dev/null; then
		switch_back_vt
		return 1
	fi
	partprobe "${DATADEV}" 2>/dev/null || true
	mdev -s 2>/dev/null || true
	sleep 1

	# Re-read partition devices (UUIDs may change; we use same device names p1/p2/p3)
	BOOT_PARTITION="${DATADEV}p1"
	IMAGE_PARTITION="${DATADEV}p2"
	DATA_PARTITION="${DATADEV}p3"
	[ -b "${BOOT_PARTITION}" ] && [ -b "${IMAGE_PARTITION}" ] && [ -b "${DATA_PARTITION}" ] || {
		switch_back_vt
		return 1
	}

	# 9) Restore boot and image from tail of new P3, then expand filesystems.
	#
	# dd writes the original (smaller) filesystem images block-for-block onto the
	# new (larger) partitions. The filesystem metadata still describes the old size.
	# After dd, each filesystem must be expanded to fill its new partition:
	# - vfat (P1): no in-place resize tool; copy files via tmpfs, mkfs at full size, copy back
	# - ext4 (P2): resize2fs expands in-place after e2fsck

	# 9a) Restore boot partition
	# count=BOOT_PART_SIZE (384), not BOOT_BACKUP_MB (385):
	# new P1 is 384 MiB (parted mkpart 1..385); writing 385 blocks overflows the
	# block device boundary and dd returns non-zero.
	progress_msg 4 9 "Restoring boot partition"
	if ! dd if="${DATA_PARTITION}" of="${BOOT_PARTITION}" bs=1M skip=0 count="${BOOT_PART_SIZE}" conv=fsync 2>/dev/null; then
		switch_back_vt
		return 1
	fi

	# 9b) Expand boot vfat to fill 384 MiB partition
	progress_msg 5 9 "Expanding boot filesystem"
	mkdir -p "${BOOTMNT}"
	if ! expand_boot_vfat "${BOOT_PARTITION}" "${BOOTMNT}"; then
		[ -c /dev/kmsg ] && echo "prepare_ota_storage: boot vfat expansion failed" >/dev/kmsg
		# Non-fatal: boot content is intact at old size, just not using full partition.
		# Init and the running system will work; only the extra space is lost.
	fi

	# 9c) Restore image partition
	# skip=BOOT_BACKUP_MB is correct: it matches the seek offset used during backup.
	progress_msg 6 9 "Restoring image partition"
	if ! dd if="${DATA_PARTITION}" of="${IMAGE_PARTITION}" bs=1M skip="${BOOT_BACKUP_MB}" count="${IMG_SIZE_MB}" conv=fsync 2>/dev/null; then
		switch_back_vt
		return 1
	fi

	# 9d) Expand image ext4 to fill 4288 MiB partition
	progress_msg 7 9 "Expanding image filesystem"
	if ! expand_image_ext4 "${IMAGE_PARTITION}"; then
		[ -c /dev/kmsg ] && echo "prepare_ota_storage: image ext4 expansion failed" >/dev/kmsg
		# Non-fatal: image content is intact at old size, future OTA may still fail
		# on space but the device will boot.
	fi
	sync

	# 10) mkfs data partition (fresh)
	progress_msg 8 9 "Preparing data partition"
	if ! /sbin/mke2fsfull -t ext4 -F -L volumio_data "${DATA_PARTITION}" 2>/dev/null; then
		if ! mke2fs -t ext4 -F -L volumio_data "${DATA_PARTITION}" 2>/dev/null; then
			mkfs.ext4 -F -L volumio_data "${DATA_PARTITION}" 2>/dev/null || true
		fi
	fi
	sync

	write_stage 0 "${DATADEV}" 2>/dev/null || true

	# 11) Remount boot and image so init can continue
	progress_msg 9 9 "Remounting partitions"
	mount -t vfat "${BOOT_PARTITION}" "${BOOTMNT}" 2>/dev/null || true
	mount -t ext4 "${IMAGE_PARTITION}" "${IMAGEMNT}" 2>/dev/null || true
	switch_back_vt
	return 0
}
